APP_ENV=development
PORT=3000

ASR_PROVIDER=mock
ASR_SERVICE_URL=http://localhost:8001
ASR_RUNTIME=mock
BREEZE_ASR_MODEL_ID=MediaTek-Research/Breeze-ASR-25
BREEZE_ASR_CT2_MODEL_PATH=models/breeze-asr-25-ct2
BREEZE_ASR_DEVICE=cuda
BREEZE_ASR_COMPUTE_TYPE=int8_float16
BREEZE_ASR_LANGUAGE=zh
BREEZE_ASR_BEAM_SIZE=1
BREEZE_ASR_VAD_FILTER=true

LLM_PROVIDER=mock
LLM_SERVICE_URL=http://localhost:8002
LLM_RUNTIME=mock
GEMMA_MODEL_ID=google/gemma-4-E4B-it
GEMMA_TRANSFORMERS_DEVICE=cuda
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_THINK=false
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=gemma-4-e2b
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=google/gemma-4-E4B-it
LLM_GENERATION_TIMEOUT_S=30

TTS_PROVIDER=mock
TTS_SERVICE_URL=http://localhost:8003
TTS_RUNTIME=mock
BREEZYVOICE_REPO_PATH=
BREEZYVOICE_MODEL_PATH=MediaTek-Research/BreezyVoice
BREEZYVOICE_SPEAKER_PROMPT_AUDIO_PATH=
BREEZYVOICE_SPEAKER_PROMPT_TEXT=
BREEZYVOICE_PYTHON=python
BREEZYVOICE_TIMEOUT_S=45
BREEZYVOICE_OUTPUT_DIR=/tmp/jarvis-breezyvoice-audio
OPENAI_TTS_BASE_URL=http://localhost:9003/v1
OPENAI_TTS_API_KEY=
OPENAI_TTS_MODEL=breezyvoice
BREEZYVOICE_CACHE_DIR=/tmp/jarvis-breezyvoice-audio/cache
BREEZYVOICE_WARMUP_ENABLED=true
BREEZYVOICE_WARMUP_TEXT=好，我在。
BREEZYVOICE_WARMUP_TEXTS=
BREEZYVOICE_WARMUP_TIMEOUT_S=60

ENABLE_EMOTION=true
EMOTION_PROVIDER=mock
EMOTION_SERVICE_URL=http://localhost:8004

CONVERSATION_STORE=memory
MAX_RECENT_MESSAGES=10

REPLY_MAX_CHARS=18
TOTAL_TIMEOUT_MS=3000
BODY_LIMIT_BYTES=26214400
ASR_TIMEOUT_MS=1000
LLM_TIMEOUT_MS=800
TTS_TIMEOUT_MS=1200
EMOTION_TIMEOUT_MS=300

ENABLE_PLAYBACK_DELAY=true
PLAYBACK_DELAY_MIN_MS=1000
PLAYBACK_DELAY_MAX_MS=2000

TTS_LONG_FORM_ENABLED=false
TTS_MAX_PARALLEL_CHUNKS=3
TTS_TARGET_CHUNK_SECONDS=4
TTS_SENTENCE_SILENCE_MS=160
MAX_PARALLEL_TTS_WORKERS=3
CHUNK_TARGET_SECONDS=4
SILENCE_PADDING_MS=120
TTS_MODEL_VERSION=breezyvoice-default

NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3000
